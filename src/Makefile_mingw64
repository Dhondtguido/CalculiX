CC := gcc
FC := gfortran

CFLAGS += -Wall -g -DARCH="Linux" -DARPACK -DMATRIXSTORAGE
CFLAGS += -DINTSIZE64
CFLAGS += -I ${MINGW_PREFIX}/include/spooles -DSPOOLES

FFLAGS += -Wall -g -cpp
FFLAGS += -fdefault-integer-8 -Wno-implicit-function-declaration

LDFLAGS = -lspooles -larpack_64 -lopenblas_64 -lstdc++

.c.o :
	$(CC) $(CFLAGS) -c $<
.f.o :
	$(FC) $(FFLAGS) -c $<

include Makefile.inc

SCCXMAIN = CalculiX.c

OCCXF = $(SCCXF:.f=.o)
OCCXC = $(SCCXC:.c=.o)
OCCXMAIN = $(SCCXMAIN:.c=.o)

CalculiX: $(OCCXMAIN) CalculiX.a
	$(CC) $(CFLAGS) -c CalculiX.c;\
	$(FC) $(FFLAGS) -o $@ $(OCCXMAIN) CalculiX.a $(LDFLAGS)

CalculiX.a: $(OCCXF) $(OCCXC)
	ar vr $@ $?
